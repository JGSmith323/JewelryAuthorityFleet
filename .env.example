# ============================================================
#  JEWELRY AUTHORITY - ENVIRONMENT CONFIGURATION
#  Copy this file to .env and fill in your credentials.
#  See API_KEYS.md for step-by-step setup guides.
# ============================================================

# -- SERVER ---------------------------------------------------
PORT=3001
NODE_ENV=development

# -- ANTHROPIC (Claude AI Chat) -------------------------------
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# -- EBAY -----------------------------------------------------
# Create an app at: https://developer.ebay.com/
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_DEV_ID=your_ebay_dev_id_here
EBAY_OAUTH_TOKEN=your_ebay_oauth_token_here
EBAY_ENVIRONMENT=sandbox    # Change to 'production' when ready

# -- SHOPIFY --------------------------------------------------
# Create a private app in your Shopify admin: Settings -> Apps -> Develop apps
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here
SHOPIFY_API_VERSION=2024-01

# -- BUSINESS WEBSITE -----------------------------------------
# Configure based on your website platform (WooCommerce, custom, etc.)
WEBSITE_API_URL=https://your-jewelry-website.com/api
WEBSITE_API_KEY=your_website_api_key_here

# -- SALESFORCE -----------------------------------------------
# Create a Connected App in Salesforce Setup
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret_here
SALESFORCE_USERNAME=your_salesforce_username_here
SALESFORCE_PASSWORD=your_salesforce_password_here
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token_here
